# OpenAI — used by ramdocs-rag pipelines (gpt-4o-mini / gpt-4o).
OPENAI_API_KEY=

# Langfuse — automatic LLM tracing (drop-in via langfuse.openai).
# Leave empty to disable; the OpenAIClient transparently falls back to plain openai.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Path to the RAMDocs subset. Leave unset to use ../data/ramdocs_subset.json
# (relative to the demo backend). Override only when running outside the repo.
# RAMDOCS_SUBSET_PATH=

# Optional model overrides (defaults match ramdocs-rag).
# OPENAI_MODEL_ANALYZER=gpt-4o-mini
# OPENAI_MODEL_MEDIATOR=gpt-4o
