# Run artefacts: commit only _baseline, _reports and _journal; everything else stays local.
runs/*
!runs/_baseline/
!runs/_reports/
!runs/_journal.md
!runs/_WIP.md
!runs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environment (kept at the Egzakta/ level)
.venv/

# HuggingFace / sentence-transformers caches
data/hf_cache/

# Editors
.idea/
.vscode/
