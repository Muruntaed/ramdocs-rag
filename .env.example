# Copy to .env and fill in the real values. Do NOT commit .env.

# --- OpenAI: used by every pipeline (analyzer + evaluator + mediator + skeptic).
OPENAI_API_KEY=
# Default models. Pipelines read these via env; sensible defaults are baked in.
OPENAI_MODEL_ANALYZER=gpt-4o-mini
OPENAI_MODEL_MEDIATOR=gpt-4o

# --- Langfuse: optional automatic LLM tracing.
# When both keys are set, core/llm.py transparently switches to ``langfuse.openai``;
# leave empty to disable. No code changes required either way.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- HuggingFace dataset cache (optional override).
HF_HOME=./data/hf_cache

# --- Retrieval tuning (override pipeline defaults).
# RETRIEVAL_TOP_K=8
